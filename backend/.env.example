# Copy this file to `.env` (same folder as manage.py) and fill in real values.
# The `.env` file must NEVER be committed to git.

# --- Core ---
# Generate one with:  python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change-me-to-a-random-50-char-string

# true for local development, false (or omit) in production
DJANGO_DEBUG=true

# Comma-separated. In production set your real domain(s), e.g. nightvision.com.np,www.nightvision.com.np
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated origins allowed to POST (scheme required).
# In production e.g. https://nightvision.com.np
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000,http://127.0.0.1:8000

# --- Database ---
# 'sqlite' (default, uses db.sqlite3) or 'postgres'
DJANGO_DB_ENGINE=sqlite

# Only used when DJANGO_DB_ENGINE=postgres
POSTGRES_DB=nightvision_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- Email (password reset codes) ---
# 'console' (default: codes are printed to the server console, for development)
# or 'smtp' with the settings below for real delivery in production.
DJANGO_EMAIL_BACKEND=console
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
DJANGO_DEFAULT_FROM_EMAIL=no-reply@nightvision.com.np

# --- Production security (only apply when DJANGO_DEBUG=false) ---
# Redirect all HTTP to HTTPS (default true in production)
DJANGO_SECURE_SSL_REDIRECT=true
# HTTP Strict Transport Security max-age in seconds
DJANGO_HSTS_SECONDS=3600
# Set to true when Django runs behind a TLS-terminating proxy (nginx, etc.)
DJANGO_BEHIND_PROXY=false
